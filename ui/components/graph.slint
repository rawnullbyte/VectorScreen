import { Theme } from "../theme.slint";

export component TemperatureGraph inherits Rectangle {
    // ── Properties ──
    in property <[float]> data-points: [];
    in property <float> min-y: 0;
    in property <float> max-y: 260;
    in property <color> line-color: Theme.accent-red;
    in property <color> grid-color: Theme.border-default;
    in property <int> grid-count: 5;
    in property <string> title: "";

    // ── Styling ──
    background: Theme.bg-secondary;
    border-radius: Theme.radius-md;
    border-width: 1px;
    border-color: Theme.border-default;
    clip: true;

    // ── Layout Constants ──
    property <length> pad-left: 44px;
    property <length> pad-right: 12px;
    property <length> pad-top: 32px;
    property <length> pad-bottom: 20px;
    property <length> plot-w: self.width - pad-left - pad-right;
    property <length> plot-h: self.height - pad-top - pad-bottom;
    property <float> y-range: max(0.001, max-y - min-y);

    // ── Title ──
    if (title != ""): Text {
        x: pad-left;
        y: 8px;
        text: root.title;
        color: Theme.text-secondary;
        font-size: Theme.font-sm;
    }

    // ── Horizontal Grid Lines (max 5, visibility by grid-count) ──
    for gi in [0, 1, 2, 3, 4]: Rectangle {
        visible: gi < root.grid-count;
        x: pad-left;
        y: pad-top + plot-h * gi / max(1, root.grid-count - 1);
        width: plot-w;
        height: 1px;
        background: grid-color.with-alpha(0.4);
    }

    // ── Y-Axis Labels ──
    for gi in [0, 1, 2, 3, 4]: Text {
        visible: gi < root.grid-count;
        x: 0;
        width: pad-left - 4px;
        y: pad-top + plot-h * gi / max(1, root.grid-count - 1) - 5px;
        text: "" + round(max-y - y-range * gi / max(1, root.grid-count - 1));
        color: Theme.text-muted;
        font-size: Theme.font-xs;
        horizontal-alignment: right;
    }

    // ── Line Segments (Rectangle per consecutive pair) ──
    for item[idx] in root.data-points: Rectangle {
        visible: idx < root.data-points.length - 1;

        property <length> x1: pad-left + plot-w * idx / max(1, root.data-points.length - 1);
        property <length> y1: pad-top + plot-h * (1 - (item - min-y) / y-range);
        property <length> next-x: pad-left + plot-w * (idx + 1) / max(1, root.data-points.length - 1);
        property <float> next-val: root.data-points[min(idx + 1, root.data-points.length - 1)];
        property <length> next-y: pad-top + plot-h * (1 - (next-val - min-y) / y-range);

        // Position at the midpoint between the two endpoints
        x: min(x1, next-x);
        y: min(y1, next-y);
        width: max(1px, abs(next-x - x1));
        height: max(1px, abs(next-y - y1));
        background: root.line-color;
    }

    // ── Data Point Markers ──
    for item[idx] in root.data-points: Rectangle {
        property <length> px: pad-left + plot-w * (root.data-points.length <= 1 ? 0.5 : idx / max(1, root.data-points.length - 1));
        property <length> py: pad-top + plot-h * (1 - (item - min-y) / y-range);
        x: px - 3px;
        y: py - 3px;
        width: 6px;
        height: 6px;
        border-radius: 3px;
        background: root.line-color;
        border-width: 1px;
        border-color: Theme.bg-secondary;
    }

    // ── No Data Placeholder ──
    if (root.data-points.length == 0): VerticalLayout {
        x: pad-left;
        y: pad-top;
        width: plot-w;
        height: plot-h;
        alignment: center;

        Text {
            text: "No data";
            color: Theme.text-muted;
            font-size: Theme.font-md;
            horizontal-alignment: center;
        }
    }

    // ── X-Axis Label ──
    Text {
        x: pad-left;
        y: self.height - 14px;
        width: plot-w;
        text: "Time";
        color: Theme.text-muted;
        font-size: Theme.font-xs;
        horizontal-alignment: center;
    }
}
