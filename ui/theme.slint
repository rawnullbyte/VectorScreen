// SaaS Dark Design System for Vector Screen
// All visual tokens centralized here for consistency across the UI

export global Theme {
    // ── Background Colors ──
    in-out property<color> bg-primary: #0f1117;
    in-out property<color> bg-secondary: #1a1d27;
    in-out property<color> bg-tertiary: #252836;

    // ── Text Colors ──
    in-out property<color> text-primary: #ffffff;
    in-out property<color> text-secondary: #a0a3b1;
    in-out property<color> text-muted: #6b6f7d;

    // ── Accent Colors ──
    in-out property<color> accent-blue: #3b82f6;
    in-out property<color> accent-green: #22c55e;
    in-out property<color> accent-red: #ef4444;
    in-out property<color> accent-orange: #f97316;

    // ── Border Colors ──
    in-out property<color> border-default: #2d3040;
    in-out property<color> border-focus: #3b82f6;

    // ── Spacing Tokens ──
    in-out property<length> spacing-xs: 4px;
    in-out property<length> spacing-sm: 8px;
    in-out property<length> spacing-md: 16px;
    in-out property<length> spacing-lg: 24px;

    // ── Border Radius ──
    in-out property<length> radius-sm: 4px;
    in-out property<length> radius-md: 8px;
    in-out property<length> radius-lg: 12px;

    // ── Font Sizes ──
    in-out property<length> font-xs: 10px;
    in-out property<length> font-sm: 12px;
    in-out property<length> font-md: 14px;
    in-out property<length> font-lg: 18px;
    in-out property<length> font-xl: 24px;
}
